APP_NAME="Lead Intelligence System"
APP_ENV=production
APP_KEY=                            # Run: php artisan key:generate --show
APP_DEBUG=false
APP_URL=https://leadintel.razertechnology.com

LOG_CHANNEL=daily
LOG_LEVEL=error

# ---- Database (matches lead-intelligence-db container) ----
DB_CONNECTION=mysql
DB_HOST=lead-intelligence-db
DB_PORT=3306
DB_DATABASE=lead_intelligence_system
DB_USERNAME=leadintel
DB_PASSWORD=                        # Set a strong password

# ---- Cache / Queue / Session (database driver — no Redis needed) ----
CACHE_STORE=database
QUEUE_CONNECTION=database
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_DOMAIN=leadintel.razertechnology.com
SESSION_SECURE_COOKIE=true

# ---- Sanctum (SPA auth) ----
SANCTUM_STATEFUL_DOMAINS=leadintel.razertechnology.com

# ---- Mail ----
MAIL_MAILER=smtp
MAIL_HOST=
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=noreply@razertechnology.com
MAIL_FROM_NAME="Lead Intelligence"

# ---- Google Places API ----
GOOGLE_PLACES_API_KEY=

# ---- Anthropic / Claude (lead scoring) ----
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# ---- SMS (Africa's Talking or compatible) ----
AT_API_KEY=
AT_USERNAME=
AT_SENDER_ID=

# ---- Lead Collection ----
LEADS_DAILY_LIMIT=100
LEADS_MIN_REVIEWS_COUNT=10
LEADS_MIN_REVIEW_YEAR=0

# ---- Outreach ----
OUTREACH_DAILY_LIMIT=20
OUTREACH_SMS_DAILY_LIMIT=30
OUTREACH_MIN_AI_SCORE=7
OUTREACH_MIN_DELAY=20
OUTREACH_MAX_DELAY=60
FOLLOW_UP_DAYS=4
SMS_FOLLOW_UP_DAYS=3
FOLLOW_UP_NOTIFICATION_EMAIL=
